# Átria Veículos - Environment Variables Configuration

# ===================================
# SEO CONFIGURATION
# ===================================

# Base URL for SEO (canonical URLs, sitemap generation)
# Production: https://atriaveiculos.com.br
# Staging: https://staging.atriaveiculos.com.br
VITE_BASE_URL=https://atriaveiculos.com.br

# ===================================
# ANALYTICS CONFIGURATION
# ===================================

# Google Tag Manager Container ID (required for analytics)
# Format: GTM-XXXXXXX
# Get from: https://tagmanager.google.com
GTM_CONTAINER_ID=GTM-XXXXXXX

# Google Analytics 4 Measurement ID (required for GA4 tracking)
# Format: G-XXXXXXXXXX
# Get from: Google Analytics > Admin > Property > Data Streams > Web
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel ID (required for Facebook/Meta tracking)
# Format: 1234567890123456 (only numbers)
# Get from: Meta Business Manager > Events Manager
META_PIXEL_ID=1234567890123456

# ===================================
# CLOUDINARY CONFIGURATION
# ===================================

# Cloudinary credentials for image optimization
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===================================
# FIREBASE CONFIGURATION
# ===================================

# Firebase SDK configuration (for client-side Firestore/Auth/Storage)
# Get from: Firebase Console > Project > Project Settings
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# Firebase Admin SDK token (for server-side operations)
FIREBASE_TOKEN=your_firebase_token

# ===================================
# OPTIONAL CONFIGURATION
# ===================================

# Google Analytics additional configuration (optional)
# For enhanced tracking and conversions
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===================================
# AUTOCONF API (Estoque)
# ===================================
AUTOCONF_API_URL=https://api.autoconf.com.br
AUTOCONF_BEARER=your_bearer_token
AUTOCONF_TOKEN=your_revenda_token

# ===================================
# OPENAI (uso futuro - descricoes IA)
# ===================================
OPENAI_API_KEY=

# ===================================
# ADMIN CREDENTIALS
# ===================================
ADMIN_USER=admin
ADMIN_PASS=atria2024

# Development flags
NODE_ENV=production
VITE_ENV=production