run = "npm run dev"
entrypoint = "src/main.jsx"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_11"

[deployment]
run = ["sh", "-c", "npm run preview"]

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 4173
externalPort = 4173

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[env]
PATH = "/home/runner/$REPL_SLUG/.config/npm/node_global/bin:/home/runner/$REPL_SLUG/node_modules/.bin:$PATH"
