{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist/public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/autoconf/**", "function": { "functionId": "autoconf", "region": "southamerica-east1" } },
      { "source": "/api/sances/**", "function": { "functionId": "sances", "region": "southamerica-east1" } },
      { "source": "/api/hypergestor-test", "function": { "functionId": "hypergestorTest", "region": "southamerica-east1" } },
      { "source": "/api/hypergestor-send", "function": { "functionId": "hypergestorSend", "region": "southamerica-east1" } },
      { "source": "/api/google-reviews", "function": { "functionId": "googleReviews", "region": "southamerica-east1" } },
      { "source": "/sitemap.xml", "function": { "functionId": "sitemap", "region": "southamerica-east1" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "redirects": [
      { "source": "/inventory-list-01**", "destination": "/estoque", "type": 301 },
      { "source": "/veiculos**",          "destination": "/estoque", "type": 301 },
      { "source": "/listings**",          "destination": "/estoque", "type": 301 },
      { "source": "/seminovos**",         "destination": "/estoque", "type": 301 },
      { "source": "/carros-usados**",     "destination": "/estoque", "type": 301 },
      { "source": "/blog-list-02**",      "destination": "/blog",    "type": 301 },
      { "source": "/loan-calculator**",   "destination": "/simulador","type": 301 },
      { "source": "/about**",             "destination": "/sobre",   "type": 301 },
      { "source": "/compare**",           "destination": "/comparar","type": 301 },
      { "source": "/venda-seu-carro**",   "destination": "/vender",  "type": 301 },
      { "source": "/nossas-lojas**",      "destination": "/sobre-atria-veiculos-campinas-sp", "type": 301 },
      { "source": "/consignacao**",       "destination": "/vender-carro-usado-campinas-sp",   "type": 301 },
      { "source": "/ofertas**",           "destination": "/estoque-carros-usados-seminovos-campinas-sp", "type": 301 },
      { "source": "/quero-vender**",      "destination": "/vender-carro-usado-campinas-sp",   "type": 301 }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|svg|webp|avif|ico)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "**/*.@(woff|woff2|ttf|eot|otf)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
      }
    ]
  }
}
